<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
</head>
<body>
    <header>
        <h1>Trending Deals</h1>
    </header>

    <nav>
        <%- include("partials/nav.ejs") %>
    </nav>

    <main class="container mt-4">
        <% if (deals.length == 0) { %>
            <p>No trending deals available at the moment.</p>
        <% } %>

        <div class="row">
            <% for (let deal of deals) { %>
                <div class="col-md-4 mb-4">
                    <div class="card p-3 h-100 search-card">
                        <h3><%= deal.title %></h3>

                        <% if (deal.thumb) { %>
                            <img src="<%= deal.thumb %>" alt="<%= deal.title %>">
                        <% } %>

                        <p><strong>Normal Price:</strong> $<%= parseFloat(deal.normalPrice).toFixed(2) %></p>
                        <p><strong>Sale Price:</strong> $<%= parseFloat(deal.salePrice).toFixed(2) %></p>
                        <p><strong>Discount:</strong> <%= parseFloat(deal.savings).toFixed(2) %>%</p>
                        <p><strong>Metacritic Score:</strong> <%= deal.metacriticScore || "N/A" %></p>

                        <% if (deal.releaseDate) { %>
                            <p><strong>Release Date:</strong> <%= new Date(deal.releaseDate * 1000).toLocaleDateString() %></p>
                        <% } else { %>
                            <p><strong>Release Date:</strong> N/A</p>
                        <% } %>

                        <button 
                            class="btn btn-secondary mb-2" 
                            onclick="window.location.href='/gameInfo?gameName=<%= encodeURIComponent(deal.title) %>'">
                            View Game Info
                        </button>

                        <a 
                            href="https://www.cheapshark.com/redirect?dealID=<%= deal.dealID %>" 
                            target="_blank" 
                            class="btn btn-primary">
                            Go to Store Page
                        </a>
                    </div>
                </div>
            <% } %>
        </div>

        <% if (totalPages > 1) { %>
            <div class="d-flex justify-content-center align-items-center gap-3 mb-4">
                <% if (currentPage > 1) { %>
                    <a class="btn btn-outline-primary" href="/trending?page=<%= currentPage - 1 %>">
                        Previous
                    </a>
                <% } %>

                <span>Page <%= currentPage %> of <%= totalPages %></span>

                <% if (currentPage < totalPages) { %>
                    <a class="btn btn-outline-primary" href="/trending?page=<%= currentPage + 1 %>">
                        Next
                    </a>
                <% } %>
            </div>
        <% } %>
    </main>

    <footer>
        <%- include("partials/footer.ejs") %>
    </footer>
</body>
</html>