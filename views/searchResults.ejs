<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
</head>
<body>
    <header>
        <h1>Search Results</h1>
        <h2>Results for "<%= gameTitle %>"</h2>
    </header>

    <nav>
        <%- include("partials/nav.ejs") %>
    </nav>

    <main class="container mt-4">
        <% if (games.length == 0) { %>
            <p>No games found.</p>
        <% } %>

        <% for (let game of games) { %>
            <div class="card mb-3 p-3">
                <h3><%= game.name %></h3>

                <% if (game.background_image) { %>
                    <img src="<%= game.background_image %>" alt="<%= game.name %>" style="max-width: 250px;">
                <% } %>
                <p>Released: <%= game.released || "N/A" %></p>

                <a href="/gameInfo?gameId=<%= game.id %>" class="btn btn-primary">
                    View Game
                </a>
            </div>
        <% } %>
    </main>

    <footer>
        <%- include("partials/footer.ejs") %>
    </footer>
</body>
</html>