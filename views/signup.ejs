<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head.ejs") %>
</head>

<body class="landing-body">
  <main class="landing-page">

    <section class="hero-panel">
      <div class="hero-content">
        <h1>Game<span class="go-red">Go</span></h1>
        <p class="hero-text">
          Your hub for tracking games, reviews, and today’s hottest deals.
        </p>
      </div>
    </section>

    <section class="login-panel">
      <div class="login-card">

        <h2>Create Account</h2>
        <p class="login-subtitle">Start tracking your favorite games today.</p>

        <% if (typeof(signupError) !== "undefined") { %>
          <div class="error-message"><%= signupError %></div>
        <% } %>

        <form action="/signup" method="POST">

          <div class="mb-3 text-center">
            <label for="username">Username</label>
            <input 
              type="text" 
              name="username" 
              id="username" 
              class="form-control custom-input"
              placeholder="Choose a username"
            >
          </div>

          <div class="mb-3 text-center">
            <label for="password">Password</label>
            <input 
              type="password" 
              name="password" 
              id="password" 
              class="form-control custom-input"
              placeholder="Create a password"
            >
          </div>

          <button type="submit" class="btn login-btn">Create Account</button>
          <a href="/" class="btn signup-btn">Back to Login</a>

        </form>

      </div>
    </section>

  </main>
</body>
</html>