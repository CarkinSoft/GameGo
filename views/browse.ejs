<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
</head>
<body>
    <header>
        <h1>Browse Games</h1>
    </header>

    <nav>
        <%- include("partials/nav.ejs") %>
    </nav>

    <main class="container mt-4">

        <section class="card mb-4 p-3">
            <h2>Recommended For You</h2>

            <% if (topGenre) { %>
                <p>Based on your library, your top genre is <strong><%= topGenre %></strong>.</p>
            <% } else { %>
                <p>Save some games to your library and recommendations will show up here.</p>
            <% } %>

            <% if (recommendedGames.length > 0) { %>
                <div class="browse-carousel-wrapper">
                    <button class="carousel-btn left" data-track="recommendedTrack">&#10094;</button>

                    <div class="browse-track" id="recommendedTrack">
                        <% for (let game of recommendedGames) { %>
                            <a href="/gameInfo?gameId=<%= game.id %>" class="browse-card-link">
                                <div class="browse-card">
                                    <h3><%= game.name %></h3>

                                    <% if (game.background_image) { %>
                                        <img src="<%= game.background_image %>" alt="<%= game.name %>">
                                    <% } %>

                                    <p><strong>Released:</strong> <%= game.released || "N/A" %></p>
                                    <p><strong>Rating:</strong> <%= game.rating || "N/A" %></p>
                                </div>
                            </a>
                        <% } %>
                    </div>

                    <button class="carousel-btn right" data-track="recommendedTrack">&#10095;</button>
                </div>
            <% } else if (topGenre) { %>
                <p>No recommendations found yet for your current library.</p>
            <% } %>
        </section>

        <section class="card mb-4 p-3">
            <h2>Popular Titles</h2>
            <p>Browse some of the most popular games right now.</p>

            <div class="browse-carousel-wrapper">
                <button class="carousel-btn left" data-track="popularTrack">&#10094;</button>

                <div class="browse-track" id="popularTrack">
                    <% for (let game of popularGames) { %>
                        <a href="/gameInfo?gameId=<%= game.id %>" class="browse-card-link">
                            <div class="browse-card">
                                <h3><%= game.name %></h3>

                                <% if (game.background_image) { %>
                                    <img src="<%= game.background_image %>" alt="<%= game.name %>">
                                <% } %>

                                <p><strong>Released:</strong> <%= game.released || "N/A" %></p>
                                <p><strong>Rating:</strong> <%= game.rating || "N/A" %></p>
                            </div>
                        </a>
                    <% } %>
                </div>

                <button class="carousel-btn right" data-track="popularTrack">&#10095;</button>
            </div>
        </section>

        <section class="card mb-4 p-3">
            <h2>Top Rated Games</h2>
            <p>These are some of the highest rated titles.</p>

            <div class="browse-carousel-wrapper">
                <button class="carousel-btn left" data-track="topRatedTrack">&#10094;</button>

                <div class="browse-track" id="topRatedTrack">
                    <% for (let game of topRatedGames) { %>
                        <a href="/gameInfo?gameId=<%= game.id %>" class="browse-card-link">
                            <div class="browse-card">
                                <h3><%= game.name %></h3>

                                <% if (game.background_image) { %>
                                    <img src="<%= game.background_image %>" alt="<%= game.name %>">
                                <% } %>

                                <p><strong>Released:</strong> <%= game.released || "N/A" %></p>
                                <p><strong>Rating:</strong> <%= game.rating || "N/A" %></p>
                            </div>
                        </a>
                    <% } %>
                </div>

                <button class="carousel-btn right" data-track="topRatedTrack">&#10095;</button>
            </div>
        </section>

        <section class="card mb-4 p-3">
            <h2>Recent Releases</h2>
            <p>See newer games released this year.</p>

            <div class="browse-carousel-wrapper">
                <button class="carousel-btn left" data-track="recentTrack">&#10094;</button>

                <div class="browse-track" id="recentTrack">
                    <% for (let game of recentGames) { %>
                        <a href="/gameInfo?gameId=<%= game.id %>" class="browse-card-link">
                            <div class="browse-card">
                                <h3><%= game.name %></h3>

                                <% if (game.background_image) { %>
                                    <img src="<%= game.background_image %>" alt="<%= game.name %>">
                                <% } %>

                                <p><strong>Released:</strong> <%= game.released || "N/A" %></p>
                                <p><strong>Rating:</strong> <%= game.rating || "N/A" %></p>
                            </div>
                        </a>
                    <% } %>
                </div>

                <button class="carousel-btn right" data-track="recentTrack">&#10095;</button>
            </div>
        </section>

        

    </main>

    <footer>
        <%- include("partials/footer.ejs") %>
    </footer>

    <script src="/js/browse.js"></script>
</body>
</html>