<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
</head>
<body>
    <header>
        <h1>GameGo Home</h1>
        <h2>Welcome, <%= username %>!</h2>
    </header>

    <nav>
        <%- include("partials/nav.ejs") %>
    </nav>

    <main class="container my-page">

        <!-- Message of the Day -->
        <section class="card page-card mx-auto mb-4" style="max-width: 850px;">
            <h3>Message of the Day: Sup Gamers! Keep on Gaming 🙏💯❤️</h3>

            <img 
                src="/img/dealss.jpg" 
                alt="Gaming Deals"
                class="img-fluid rounded mt-2"
            >
        </section>

        <!-- Top 3 Games -->
        <section class="card page-card">
            <h3 class="mb-4">Top 3 Games</h3>

            <div id="topGames" class="row">
                <p>Loading games...</p>
            </div>
        </section>

    </main>

    <footer>
        <%- include("partials/footer.ejs") %>
    </footer>

    <script src="/js/home.js"></script>

</body>
</html>