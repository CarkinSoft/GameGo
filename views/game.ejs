<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
</head>
<body>
    <header>
        <h1><%= game.name %></h1>
    </header>

    <nav>
        <%- include("partials/nav.ejs") %>
    </nav>

    <main class="container mt-4">
        <section class="card mb-4 p-3">
            <% if (game.background_image) { %>
                <img src="<%= game.background_image %>" alt="<%= game.name %>" style="max-width: 350px;">
            <% } %>

            <p><strong>Released:</strong> <%= game.released || "N/A" %></p>
            <p><strong>RAWG Rating:</strong> <%= game.rating || "N/A" %></p>
            <p><strong>Ratings Count:</strong> <%= game.ratings_count || "N/A" %></p>
            <p><strong>Reviews Count:</strong> <%= game.reviews_count || "N/A" %></p>
            <p><strong>Metacritic:</strong> <%= game.metacritic || "N/A" %></p>
            <p><strong>Average Playtime:</strong> <%= game.playtime || "N/A" %> hours</p>
            <p><strong>ESRB Rating:</strong> <%= game.esrb_rating ? game.esrb_rating.name : "N/A" %></p>

            <p>
                <strong>Genres:</strong>
                <% if (game.genres && game.genres.length > 0) { %>
                    <%= game.genres.map(g => g.name).join(", ") %>
                <% } else { %>
                    N/A
                <% } %>
            </p>

            <p>
                <strong>Platforms:</strong>
                <% if (game.platforms && game.platforms.length > 0) { %>
                    <%= game.platforms.map(p => p.platform.name).join(", ") %>
                <% } else { %>
                    N/A
                <% } %>
            </p>

            <p>
                <strong>Developers:</strong>
                <% if (game.developers && game.developers.length > 0) { %>
                    <%= game.developers.map(d => d.name).join(", ") %>
                <% } else { %>
                    N/A
                <% } %>
            </p>

            <p>
                <strong>Publishers:</strong>
                <% if (game.publishers && game.publishers.length > 0) { %>
                    <%= game.publishers.map(p => p.name).join(", ") %>
                <% } else { %>
                    N/A
                <% } %>
            </p>

            <p><strong>Website:</strong>
                <% if (game.website) { %>
                    <a href="<%= game.website %>" target="_blank"><%= game.website %></a>
                <% } else { %>
                    N/A
                <% } %>
            </p>

            <p><strong>Description:</strong></p>
            <p><%= game.description_raw || "No description available." %></p>
        </section>

        <section class="card mb-4 p-3">
            <h3>Library Controls</h3>

            <% if (savedGame) { %>
                <p><strong>This game is already in your library.</strong></p>
                <p><strong>Current Status:</strong> <%= savedGame.status %></p>
                <p><strong>Favorite:</strong> <%= savedGame.is_favorite ? "Yes" : "No" %></p>

                <div id="feedbackDiv" class="mb-2"></div>

                <form id="saveGameForm" action="/saveGame" method="POST" class="mt-3">
                    <input type="hidden" name="rawg_game_id" value="<%= game.id %>">
                    <input type="hidden" name="title" value="<%= game.name %>">
                    <input type="hidden" name="cover_image" value="<%= game.background_image || '' %>">
                    <input type="hidden" name="genres" value="<%= game.genres ? game.genres.map(g => g.name).join(', ') : (savedGame.genres || '') %>">

                    <div class="mb-3">
                        <label for="status">Status:</label>
                        <select name="status" id="status" class="form-select">
                            <option value="Want to Play" <%= savedGame.status == "Want to Play" ? "selected" : "" %>>Want to Play</option>
                            <option value="Playing" <%= savedGame.status == "Playing" ? "selected" : "" %>>Playing</option>
                            <option value="Completed" <%= savedGame.status == "Completed" ? "selected" : "" %>>Completed</option>
                            <option value="Dropped" <%= savedGame.status == "Dropped" ? "selected" : "" %>>Dropped</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="is_favorite">Favorite:</label>
                        <input
                            type="checkbox"
                            name="is_favorite"
                            id="is_favorite"
                            value="1"
                            <%= savedGame.is_favorite ? "checked" : "" %>
                        >
                    </div>

                    <button type="submit" class="btn btn-success">Update Saved Game</button>
                </form>
            <% } else { %>
                <p>This game is not in your library yet.</p>

                <div id="feedbackDiv" class="mb-2"></div>

                <form id="saveGameForm" action="/saveGame" method="POST" class="mt-3">
                    <input type="hidden" name="rawg_game_id" value="<%= game.id %>">
                    <input type="hidden" name="title" value="<%= game.name %>">
                    <input type="hidden" name="cover_image" value="<%= game.background_image || '' %>">
                    <input type="hidden" name="genres" value="<%= game.genres ? game.genres.map(g => g.name).join(', ') : '' %>">

                    <div class="mb-3">
                        <label for="status">Status:</label>
                        <select name="status" id="status" class="form-select">
                            <option value="">Select One</option>
                            <option value="Want to Play">Want to Play</option>
                            <option value="Playing">Playing</option>
                            <option value="Completed">Completed</option>
                            <option value="Dropped">Dropped</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="is_favorite">Favorite:</label>
                        <input type="checkbox" name="is_favorite" id="is_favorite" value="1">
                    </div>

                    <button type="submit" class="btn btn-success">Save Game</button>
                </form>
            <% } %>
        </section>

        <section class="card mb-4 p-3">
            <h3>Add Review</h3>

            <% if (currentUserReview) { %>
                <p>You already reviewed this game.</p>
                <a href="/editReview?reviewId=<%= currentUserReview.id %>" class="btn btn-warning">Edit Your Review</a>
            <% } else { %>
                <div id="reviewFeedbackDiv" class="mb-2"></div>

                <form id="reviewForm" class="mb-4">
                    <input type="hidden" name="rawg_game_id" value="<%= game.id %>">

                    <div class="mb-3">
                        <label for="rating" class="form-label">Rating:</label>
                        <select name="rating" id="rating" class="form-select">
                            <option value="">Select One</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="review_title" class="form-label">Review Title:</label>
                        <input type="text" name="review_title" id="review_title" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label for="review_text" class="form-label">Your Review</label>
                        <textarea name="review_text" id="review_text" class="form-control" rows="4"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Submit Review</button>
                </form>
            <% } %>
        </section>

        <section class="card mb-4 p-3">
            <h3>User Reviews</h3>

            <% if (!reviews || reviews.length === 0) { %>
                <p>No reviews yet.</p>
            <% } %>

            <% if (reviews && reviews.length > 0) { %>
                <% for (let review of reviews) { %>
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <a href="/user/<%= review.user_id %>">
                                    <img
                                        src="<%= review.profile_image || '/img/defaultphoto.jpeg' %>"
                                        alt="<%= review.display_name %>"
                                        class="profile-review-img"
                                    >
                                </a>

                                <div>
                                    <a href="/user/<%= review.user_id %>" class="profile-name-link">
                                        <strong><%= review.display_name %></strong>
                                    </a>
                                    <div class="text-muted"><%= review.rating %>/5</div>
                                </div>
                            </div>

                            <h5 class="card-title"><%= review.review_title %></h5>
                            <p class="card-text"><%= review.review_text %></p>

                            <small class="text-muted d-block mb-2">
                                <%= new Date(review.created_at).toLocaleString() %>
                            </small>

                            <% if (review.user_id == userId) { %>
                                <div class="d-flex gap-2">
                                    <a href="/editReview?reviewId=<%= review.id %>" class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <form action="/deleteReview" method="POST">
                                        <input type="hidden" name="reviewId" value="<%= review.id %>">
                                        <input type="hidden" name="rawg_game_id" value="<%= review.rawg_game_id %>">
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            <% } %>
        </section>
    </main>

    <footer>
        <%- include("partials/footer.ejs") %>
    </footer>

    <script src="/js/saveGame.js"></script>
    <script src="/js/review.js"></script>
</body>
</html>