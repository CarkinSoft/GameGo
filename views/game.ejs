<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
</head>
<body>
    <header>
        <h1><%= game.name %></h1>
    </header>

    <nav>
        <%- include("partials/nav.ejs") %>
    </nav>

    <main class="container mt-4">
        <section class="card mb-4 p-3">
            <div class="row">
                <% if (game.background_image) { %>
                    <div class="col-md-4 mb-3">
                        <img src="<%= game.background_image %>" alt="<%= game.name %>" class="img-fluid rounded">
                    </div>
                <% } %>
                <div class="col">
                    <table class="table table-sm">
                        <tbody>
                            <tr><th>Released</th><td><%= game.released || "N/A" %></td></tr>
                            <tr><th>RAWG Rating</th><td><%= game.rating || "N/A" %> / 5 (<%= game.ratings_count || 0 %> ratings)</td></tr>
                            <% if (game.metacritic) { %><tr><th>Metacritic</th><td><%= game.metacritic %></td></tr><% } %>
                            <tr><th>Avg. Playtime</th><td><%= game.playtime || "N/A" %> hours</td></tr>
                            <tr><th>ESRB Rating</th><td><%= game.esrb_rating ? game.esrb_rating.name : "N/A" %></td></tr>
                            <tr>
                                <th>Genres</th>
                                <td>
                                    <% if (game.genres && game.genres.length > 0) { %>
                                        <%= game.genres.map(g => g.name).join(", ") %>
                                    <% } else { %>N/A<% } %>
                                </td>
                            </tr>
                            <tr>
                                <th>Platforms</th>
                                <td>
                                    <% if (game.platforms && game.platforms.length > 0) { %>
                                        <%= game.platforms.map(p => p.platform.name).join(", ") %>
                                    <% } else { %>N/A<% } %>
                                </td>
                            </tr>
                            <tr>
                                <th>Developers</th>
                                <td>
                                    <% if (game.developers && game.developers.length > 0) { %>
                                        <%= game.developers.map(d => d.name).join(", ") %>
                                    <% } else { %>N/A<% } %>
                                </td>
                            </tr>
                            <tr>
                                <th>Publishers</th>
                                <td>
                                    <% if (game.publishers && game.publishers.length > 0) { %>
                                        <%= game.publishers.map(p => p.name).join(", ") %>
                                    <% } else { %>N/A<% } %>
                                </td>
                            </tr>
                            <% if (game.website) { %>
                                <tr><th>Website</th><td><a href="<%= game.website %>" target="_blank"><%= game.website %></a></td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <% if (game.description_raw) { %>
                <hr>
                <p><%= game.description_raw %></p>
            <% } %>
        </section>

        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <section class="card page-card h-100 p-4 text-center">
                    <h2>Current Deal</h2>

                    <% if (dealInfo) { %>
                        <p><strong>Sale Price:</strong> $<%= dealInfo.salePrice %></p>
                        <p><strong>Normal Price:</strong> $<%= dealInfo.normalPrice %></p>
                        <p><strong>Discount:</strong> <%= Math.round(dealInfo.savings) %>% off</p>

                        <div class="deal-btn-wrap mt-3">
                            <a 
                                href="https://www.cheapshark.com/redirect?dealID=<%= dealInfo.dealID %>" 
                                target="_blank" 
                                class="btn btn-primary game-btn">
                                Go to Store Page
                            </a>
                        </div>
                    <% } else { %>
                        <p>No current deal available.</p>
                    <% } %>
                </section>
            </div>

            <div class="col-md-6">
                <section class="card page-card h-100 p-4 text-center">
                    <h2>Library Controls</h2>

                    <% if (savedGame) { %>
                        <p><strong>This game is already in your library.</strong></p>
                        <p><strong>Current Status:</strong> <%= savedGame.status %></p>
                        <p><strong>Favorite:</strong> <%= savedGame.is_favorite ? "Yes" : "No" %></p>
                    <% } %>

                    <form id="saveGameForm" class="game-form-narrow">
                        <input type="hidden" name="rawg_game_id" value="<%= game.id %>">
                        <input type="hidden" name="title" value="<%= game.name %>">
                        <input type="hidden" name="cover_image" value="<%= game.background_image %>">
                        <input type="hidden" name="genres" value="<%= game.genres.map(g => g.name).join(', ') %>">

                        <div class="mb-3 text-start">
                            <label class="form-label fw-bold">Status</label>
                            <select name="status" class="form-select">
                                <option value="">Select One</option>
                                <option value="Want to Play" <%= savedGame && savedGame.status == "Want to Play" ? "selected" : "" %>>Want to Play</option>
                                <option value="Playing" <%= savedGame && savedGame.status == "Playing" ? "selected" : "" %>>Playing</option>
                                <option value="Completed" <%= savedGame && savedGame.status == "Completed" ? "selected" : "" %>>Completed</option>
                                <option value="Dropped" <%= savedGame && savedGame.status == "Dropped" ? "selected" : "" %>>Dropped</option>
                            </select>
                        </div>

                        <div class="form-check d-flex justify-content-center mb-3">
                            <input 
                                class="form-check-input me-2" 
                                type="checkbox" 
                                name="is_favorite" 
                                value="1"
                                id="favoriteCheck"
                                <%= savedGame && savedGame.is_favorite ? "checked" : "" %>
                            >
                            <label class="form-check-label" for="favoriteCheck">
                                Favorite
                            </label>
                        </div>

                        <div class="form-btn-wrap">
                            <button type="submit" class="btn btn-success game-btn">
                                <%= savedGame ? "Update Saved Game" : "Save Game" %>
                            </button>
                        </div>
                    </form>
                    <div id="feedbackDiv" class="mt-3 fw-bold"></div>
                </section>
            </div>
        </div>
        </section>

        <section class="card mb-4 p-3">
            <h3>Add Review</h3>

            <% if (currentUserReview) { %>
                <p>You already reviewed this game.</p>
                <a href="/editReview?reviewId=<%= currentUserReview.id %>" class="btn btn-warning">Edit Your Review</a>
            <% } else { %>
                <div id="reviewFeedbackDiv" class="mb-2"></div>

                <form id="reviewForm" class="mb-4">
                    <input type="hidden" name="rawg_game_id" value="<%= game.id %>">

                    <div class="mb-3">
                        <label for="rating" class="form-label">Rating:</label>
                        <select name="rating" id="rating" class="form-select">
                            <option value="">Select One</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="review_title" class="form-label">Review Title:</label>
                        <input type="text" name="review_title" id="review_title" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label for="review_text" class="form-label">Your Review</label>
                        <textarea name="review_text" id="review_text" class="form-control" rows="4"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Submit Review</button>
                </form>
            <% } %>
        </section>

        <section class="card mb-4 p-3">
            <h3>User Reviews</h3>

            <% if (!reviews || reviews.length === 0) { %>
                <p>No reviews yet.</p>
            <% } %>

            <% if (reviews && reviews.length > 0) { %>
                <% for (let review of reviews) { %>
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <a href="/user/<%= review.user_id %>">
                                    <img
                                        src="<%= review.profile_image || '/img/defaultphoto.jpeg' %>"
                                        alt="<%= review.display_name %>"
                                        class="profile-review-img"
                                    >
                                </a>

                                <div>
                                    <a href="/user/<%= review.user_id %>" class="profile-name-link">
                                        <strong><%= review.display_name %></strong>
                                    </a>
                                    <div class="text-muted"><%= review.rating %>/5</div>
                                </div>
                            </div>

                            <h5 class="card-title"><%= review.review_title %></h5>
                            <p class="card-text"><%= review.review_text %></p>

                            <small class="text-muted d-block mb-2">
                                <%= new Date(review.created_at).toLocaleString() %>
                            </small>

                            <% if (review.user_id == userId) { %>
                                <div class="d-flex gap-2">
                                    <a href="/editReview?reviewId=<%= review.id %>" class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <form action="/deleteReview" method="POST">
                                        <input type="hidden" name="reviewId" value="<%= review.id %>">
                                        <input type="hidden" name="rawg_game_id" value="<%= review.rawg_game_id %>">
                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            <% } %>
        </section>
    </main>

    <footer>
        <%- include("partials/footer.ejs") %>
    </footer>

    <script src="/js/saveGame.js"></script>
    <script src="/js/review.js"></script>
</body>
</html>