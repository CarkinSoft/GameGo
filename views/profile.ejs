<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
</head>
<body>
    <header class="page-title">
        <h1><%= profileUser.display_name %>'s Profile</h1>
    </header>

    <nav>
        <%- include("partials/nav.ejs") %>
    </nav>

    <main class="container py-4">
        <section class="card page-card mb-4">
            <div class="card p-4 mb-4">

                <div class="row align-items-center justify-content-center text-center text-md-start">

                    <div class="col-md-3 d-flex justify-content-center mb-3 mb-md-0">
                        <img src="<%= profileUser.profile_image %>" class="profile-img-lg">
                    </div>

                    <div class="col-md-6">
                        <h2><%= profileUser.display_name %></h2>
                        <p><strong>Username:</strong> <%= profileUser.username %></p>
                        <p><strong>Bio:</strong> <%= profileUser.bio || "No bio yet." %></p>
                        <p><strong>Joined:</strong> <%= new Date(profileUser.created_at).toLocaleDateString() %></p>
                    </div>
                </div>
            </div>
            <% if (isOwnProfile) { %>
                    <div class="text-center mt-3">
                        <a href="/editProfile" class="btn btn-primary">
                            Update Profile
                        </a>
                    </div>
                <% } %>
        </section>

        <section class="card page-card mb-4">
            <div class="card-body p-4">
                <h2 class="text-center mb-4">Profile Stats</h2>

                <div class="row text-center">
                    <div class="col-md-4 mb-3">
                        <div class="border rounded p-3 bg-light">
                            <h5>Total Saved Games</h5>
                            <p class="mb-0"><%= stats.totalSaved || 0 %></p>
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="border rounded p-3 bg-light">
                            <h5>Total Favorites</h5>
                            <p class="mb-0"><%= stats.totalFavorites || 0 %></p>
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="border rounded p-3 bg-light">
                            <h5>Total Reviews</h5>
                            <p class="mb-0"><%= reviewStats.totalReviews || 0 %></p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="card page-card">
            <div class="card-body p-4">
                <h2 class="text-center mb-4">Featured Games</h2>

                <% if (!featuredGames || featuredGames.length === 0) { %>
                    <p class="text-center mb-0">No featured games selected.</p>
                <% } %>

                <div class="row">
                    <% for (let game of featuredGames) { %>
                        <div class="col-md-6 col-lg-4 mb-4">
                            <a href="/gameInfo?gameId=<%= game.rawg_game_id %>" class="text-decoration-none text-dark">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="card-body text-center">
                                        <% if (game.cover_image) { %>
                                            <img src="<%= game.cover_image %>" alt="<%= game.title %>" class="featured-thumb mb-3">
                                        <% } %>

                                        <h5 class="card-title"><%= game.title %></h5>
                                        <p class="mb-1"><strong>Status:</strong> <%= game.status %></p>
                                        <p class="mb-0"><strong>Favorite:</strong> <%= game.is_favorite ? "Yes" : "No" %></p>
                                    </div>
                                </div>
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <%- include("partials/footer.ejs") %>
    </footer>
</body>
</html>