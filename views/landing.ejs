<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head.ejs") %>
</head>

<body>
  <main class="container min-vh-100 d-flex justify-content-center align-items-start pt-5">
    
    <div class="card shadow p-4 w-100" style="max-width: 450px;">
      
      <h1 class="text-center mb-3">GAMEGO</h1>

      <p class="text-center text-muted">
        Your hub for tracking games, reviews, and today’s hottest deals.
      </p>

      <h3 class="text-center mt-3">Welcome Back</h3>
      <p class="text-center text-muted">Sign in to continue your quest.</p>

      <% if (typeof(loginError) !== "undefined") { %>
        <div class="alert alert-danger"><%= loginError %></div>
      <% } %>

      <% if (typeof(signupSuccess) !== "undefined") { %>
        <div class="alert alert-success"><%= signupSuccess %></div>
      <% } %>

      <form action="/login" method="POST">
        
        <div class="mb-3 text-start">
          <label for="username" class="form-label">Username</label>
          <input 
            type="text" 
            name="username" 
            id="username" 
            class="form-control"
          >
        </div>

        <div class="mb-3 text-start">
          <label for="password" class="form-label">Password</label>
          <input 
            type="password" 
            name="password" 
            id="password" 
            class="form-control"
          >
        </div>

        <div class="d-flex gap-2 justify-content-center">
          <button type="submit" class="btn btn-primary">Login</button>
          <a href="/signup" class="btn btn-outline-primary">Create Account</a>
        </div>

      </form>

    </div>

  </main>

  <%- include("partials/footer.ejs") %>
</body>
</html>