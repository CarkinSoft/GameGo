<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head.ejs") %>
</head>

<body class="landing-body">
  <main class="landing-page">
    <section class="hero-panel">
      <div class="hero-content">
        <h1><span class="game">Game</span><span class="go">Go</span></h1>
        <p class="hero-text">
        Your hub for tracking games, reviews, and today’s hottest deals.        </p>
      </div>
    </section>

    <section class="login-panel">
      <div class="login-card">
        <h2>Welcome Back</h2>
        <p class="login-subtitle">Sign in to continue your quest.</p>

        <% if (typeof(loginError) !== "undefined") { %>
          <div class="error-message mb-3"><%= loginError %></div>
        <% } %>

        <% if (typeof(signupSuccess) !== "undefined") { %>
          <div class="success-message mb-3"><%= signupSuccess %></div>
        <% } %>

        <form action="/login" method="POST">
          <div class="mb-3">
            <label for="username">Username</label>
            <input 
              type="text" 
              name="username" 
              id="username" 
              class="form-control custom-input"
            >
          </div>

          <div class="mb-3">
            <label for="password">Password</label>
            <input 
              type="password" 
              name="password" 
              id="password" 
              class="form-control custom-input"
            >
          </div>

          <button type="submit" class="btn login-btn">Login</button>
          <a href="/signup" class="btn signup-btn">Create Account</a>
        </form>
      </div>
    </section>
  </main>

  <%- include("partials/footer.ejs") %>
</body>
</html>